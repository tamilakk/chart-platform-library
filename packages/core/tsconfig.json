{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,

    "rootDir": "src",
    "outDir": "dist",
    "composite": true,

    "module": "CommonJS",
  },
  "include": ["src"]
}